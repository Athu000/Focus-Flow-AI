rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEBUG RULE: Allow the developer to read everything
    match /{document=**} {
      allow read: if request.auth != null && request.auth.token.email == "atharvajadhav0001@gmail.com";
    }

    // Allow anyone to read the connection test
    match /test/connection {
      allow read: if true;
    }

    // Allow authenticated users to read and write their own data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /tasks/{taskId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid || request.resource.data.uid == request.auth.uid);
    }

    match /stats/{statsId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid || request.resource.data.uid == request.auth.uid);
    }
  }
}
